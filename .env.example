# Mustafa's Mattress — Environment Variables
# Copy this file to .env and fill in your values

# Site URL (used for canonical URLs and sitemap)
VITE_SITE_URL=https://mustafasmattress.in

# Analytics (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Contact form endpoint (optional — for future backend integration)
# VITE_CONTACT_API_URL=https://api.mustafasmattress.in/contact

# Web3Forms API key (get free key at https://web3forms.com)
VITE_WEB3FORMS_KEY=your-web3forms-access-key
